@misc{kuhnle_equalstrength_2026,
	title = {{EqualStrength}: {Examining} the effectiveness of the experimental manipulations of employment and housing success in the domain of childcare.},
	copyright = {Creative Commons Attribution 4.0 International},
	shorttitle = {{EqualStrength}},
	url = {https://osf.io/nqmxp/},
	doi = {10.17605/OSF.IO/NQMXP},
	abstract = {This study is developed under a larger project, entitled "EqualStrength: Measuring Cumulative Discrimination with Field Experiment Across Settings.". The main contribution of EqualStrength is to investigate cumulative and structural forms of discrimination, outgroup prejudice and hate crimes against ethnic, racial, and religious minority groups from a cross-setting and intersectional perspective. The larger project aims to capture structural forms of ethnic and racial discrimination in the domains of employment, housing and access to childcare in 9 countries: Belgium, Czechia, Germany, Hungary, Ireland, the Netherlands, Spain, Switzerland and the United Kingdom. 

This document serves the purpose of preregistering the smaller study “EqualStrength: Examining the effectiveness of the experimental manipulations of employment and housing success in the domain of childcare”. The primary objective of this study is to assess the effectiveness of the experimental manipulations that we intend to use in the field experiments. These experimental manipulations are (the absence of) cues of success in the domains of employment and housing in messages to childcare centres. This study focuses on observing whether the designed signals are noticeable. This will be done by investigating if there are differences between the treatment groups in terms of how they rate the applicant’s (family’s) success in the labour and housing market.},
	urldate = {2026-05-06},
	publisher = {OSF Registries},
	author = {Kuhnle, Jeremy Michael Jesse and Lancee, Bram and Sprong, Stefanie and Lachkovska, Vasilena and van Oosten, Sanne and Atay, Pelin and Cebolla-Boado, Hector and Capistrano, Daniel and Creighton, Mathew and Fernández-Reino, Mariña and Fossati, Flavia and Ghekiere, Abel and Hildebrandt, Johanna and Ketevani Kapanadze and Montag, Josef and Scharle, Ágota and Bori Simonovits and Di Stasio, Valentina and Steinmetz, Stephanie and Strömberg, Ely and Suarez, Alvaro and Vass-Vigh, Veronika and Veit, Susanne and Verhaeghe, Pieter-Paul and Zschirnt, Eva},
	collaborator = {{Center for Open Science}},
	year = {2026},
